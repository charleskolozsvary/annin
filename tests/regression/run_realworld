#!/usr/bin/python3

import csv
import json
import re
import subprocess
import time
from datetime import datetime
from pathlib import Path

ROOT = Path(__file__).resolve().parent
REALWORLD_DIR = ROOT / "real_world"
RESULTS_DIR = ROOT / "results"

PDF_RE = re.compile(r"^annotation.*\.pdf$")
SUMMARY_RE = re.compile(
    r"n_annots:\s*(\d+),\s*"
    r"n_edits:\s*(\d+),\s*"
    r"n_corrs:\s*(\d+),\s*"
    r"n_autos:\s*(\d+)"
)

CSV_COLUMNS = [
    "failed",
    "log_exists",
    "n_annots",
    "n_edits",
    "n_corrs",
    "n_autos",
    "directory",
    "pdf_file",
    "runtime",
]

def discover_jobs():
    jobs = []

    for article_dir in sorted(REALWORLD_DIR.iterdir()):
        if not article_dir.is_dir():
            continue

        tex_file = article_dir / "source.tex"

        if not tex_file.exists():
            print(f"ERROR: missing source.tex in {article_dir}", flush=True)
            continue

        pdfs = [
            p for p in article_dir.iterdir()
            if p.is_file() and PDF_RE.match(p.name)
        ]

        if not pdfs:
            continue

        for pdf in sorted(pdfs):
            jobs.append((article_dir, pdf, tex_file))

    return jobs

def parse_log(log_path: Path):
    with log_path.open() as f:
        for line in f:
            m = SUMMARY_RE.search(line)
            if m:
                return tuple(int(x) for x in m.groups())

    return 0, 0, 0, 0

def run_job(job):
    article_dir, pdf_file, tex_file = job

    start = time.perf_counter()

    command = [
        "annin",
        "-a",
        '--no-svn',
        '--no-replace',
        pdf_file.name,
        tex_file.name,
    ]
    command_str = ' '.join(command)
    print(f'Running {article_dir.name}, {pdf_file.name}...', flush = True)
    result = subprocess.run(
        command,
        cwd=article_dir,
        capture_output=True,
        text=True,
        check=True,
    )

    runtime = time.perf_counter() - start

    failed = int(result.returncode != 0)

    log_path = article_dir / f"annin_{pdf_file.stem}.log"
    log_exists = int(log_path.exists())

    n_annots = n_edits = n_corrs = n_autos = 0

    if log_exists:
        n_annots, n_edits, n_corrs, n_autos = parse_log(log_path)

    return {
        "failed": failed,
        "log_exists": log_exists,
        "n_annots": n_annots,
        "n_edits": n_edits,
        "n_corrs": n_corrs,
        "n_autos": n_autos,
        "directory": article_dir.name,
        "pdf_file": pdf_file.name,
        "runtime": round(runtime, 3),
    }

def write_csv(rows):
    RESULTS_DIR.mkdir(parents=True, exist_ok=True)

    timestamp = datetime.now().strftime("%Y_%m_%d_%H-%M")

    csv_path = RESULTS_DIR / f"realworld_results_{timestamp}.csv"

    with csv_path.open("w", newline="") as f:
        writer = csv.DictWriter(f, fieldnames=CSV_COLUMNS)
        writer.writeheader()
        writer.writerows(rows)

    return csv_path


def write_run_metadata(csv_path: Path):
    """
    Points pytest to the latest run.
    """
    meta_path = RESULTS_DIR / "latest_realworld_run.json"

    with meta_path.open("w") as f:
        json.dump(
            {
                "results_csv": csv_path.name,
                "created_at": datetime.now().isoformat(timespec="minutes"),
            },
            f,
            indent=2,
        )

    return meta_path

def generate_realworld_results():
    jobs = discover_jobs()

    if not jobs:
        print("No realworld regression jobs found.", flush=True)
        return None

    rows = []

    for job in jobs:
        try:
            row = run_job(job)
            rows.append(row)
        except Exception as e:
            # keep going, but make failures visible
            article_dir, pdf_file, _ = job
            print(
                f"ERROR processing {pdf_file}: {e}",
                flush=True,
            )

            rows.append({
                "failed": 1,
                "log_exists": 0,
                "n_annots": 0,
                "n_edits": 0,
                "n_corrs": 0,
                "n_autos": 0,
                "directory": article_dir.name,
                "pdf_file": pdf_file.name,
                "runtime": 0.0,
            })

    rows.sort(key=lambda r: (r["directory"], r["pdf_file"]))

    csv_path = write_csv(rows)
    meta_path = write_run_metadata(csv_path)

    print(f"Wrote CSV: {csv_path}")
    print(f"Wrote metadata: {meta_path}")

    return csv_path

if __name__ == "__main__":
    generate_realworld_results()
